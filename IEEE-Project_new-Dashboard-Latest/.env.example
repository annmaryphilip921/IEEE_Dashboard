# ============================================================
# IEEE Dashboard - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git
# ============================================================

# --- AWS RDS PostgreSQL ---
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ieee_dashboard
DB_USER=ieee_admin
DB_PASSWORD=your_strong_password_here
DB_SSL=true

# --- Server ---
PORT=3001
NODE_ENV=production

# --- Gmail SMTP (optional for real-time email; use app password) ---
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_PASS=your_16_char_app_password

# --- AWS SES (Email) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=IEEE PCIC Conference

# --- Session Secret (use a long random string) ---
SESSION_SECRET=replace_with_64_char_random_string

# --- Optional: Admin seeding payload (JSON array), only for `node db/seed-admins.js` ---
# Example:
# ADMIN_SEED_JSON=[{"username":"admin1","password":"StrongPass123!","fullName":"Admin One","email":"admin1@ieee-project.com","role":"Super Admin"}]
ADMIN_SEED_JSON=

# --- Frontend URL (for CORS) ---
FRONTEND_URL=https://your-frontend-domain.com
